; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="P2P-IRCLikeSNS"
run/main_scene="res://ChatScene.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

WebRTCHandler="*res://WebRTCHandler.gd"
NostrGD="*res://addons/nostr_godot/nostr_gd_client.gd"

[dotnet]

project/assembly_name="P2P-IRCLikeSNS"

[editor_plugins]

enabled=PackedStringArray()

[gui]

theme/custom_font="uid://bonkdea70ejn0"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

[display]
window/size/scale_2d=2.0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[web]
canvas/export/embed_icon_in_html=true
